# ============================================================
#  voice-bridge 設定 — Raspberry Pi 5 向け
# ============================================================

# --- OpenAI 互換 API (→ OpenClaw Gateway) ---
# OpenClaw が 127.0.0.1:18789 で /v1/chat/completions を提供する想定
# ※ OpenClaw のデフォルトポートは 18789
OPENAI_API_BASE=http://127.0.0.1:18789/v1
# OpenClaw の認証トークン (openclaw onboard で設定した値を入れる)
OPENAI_API_KEY=d0e4672fb02025b674ce49665155ff94c819426eaafca2cf
# OpenClaw のモデル指定
# "openclaw" でデフォルトエージェント、"openclaw:エージェントID" で指定エージェント
OPENAI_MODEL=openclaw

# --- STT (Speech-to-Text) ---
# faster-whisper / Moonshine を選択
STT_ENGINE=faster-whisper
# モデルサイズ: tiny / base / small (Pi 5 では small 推奨)
STT_MODEL_SIZE=small
# 言語
STT_LANGUAGE=ja

# --- TTS (Text-to-Speech) ---
# VOICEVOX を優先、未起動時は Edge TTS にフォールバック
TTS_ENGINE=voicevox
VOICEVOX_URL=http://127.0.0.1:50021
# ずんだもん (speaker ID: 3 = ずんだもん ノーマル)
VOICEVOX_SPEAKER_ID=3
# フォールバック
TTS_FALLBACK=edge-tts
EDGE_TTS_VOICE=ja-JP-NanamiNeural

# --- オーディオデバイス (Pi 向け) ---
# USBスピーカーフォンのデバイス名 (arecord -l / aplay -l で確認)
# 空欄ならデフォルトデバイスを使用
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
# サンプルレート
AUDIO_SAMPLE_RATE=16000

# --- 動作モード ---
# chat: 会話モード
MODE=chat
# ウェイクワード (空欄で常時リスニング)
WAKE_WORD=ずんだもん
# 無音タイムアウト (秒)
SILENCE_TIMEOUT=2.0
# 最大録音時間 (秒)
MAX_RECORD_SECONDS=30

# --- ログ ---
LOG_LEVEL=INFO
LOG_FILE=/opt/ai-secretary/voice-bridge/logs/voice-bridge.log
