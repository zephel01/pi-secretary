# ============================================================
#  voice-bridge 設定 — Raspberry Pi 5 向け
# ============================================================

# --- LLM バックエンド ---
# openai:   OpenAI API / OpenAI 互換 (OpenClaw, GLM, Groq, Together 等)
# gemini:   Google Gemini API
LLM_BACKEND=openai

# --- OpenAI 互換 API ---
# LLM_BACKEND=openai の場合に使用
OPENAI_API_BASE=http://127.0.0.1:18789/v1
OPENAI_API_KEY=d0e4672fb02025b674ce49665155ff94c819426eaafca2cf
OPENAI_MODEL=openclaw
#
# ◆ 切り替え例:
# OpenAI GPT-4o:
#   OPENAI_API_BASE=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o
#
# GLM (智谱AI):
#   OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
#   OPENAI_API_KEY=your-glm-api-key
#   OPENAI_MODEL=glm-4-flash
#
# Groq:
#   OPENAI_API_BASE=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile

# --- Google Gemini API ---
# LLM_BACKEND=gemini の場合に使用
# pip3 install google-generativeai --break-system-packages
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- ウェブ検索 (DuckDuckGo) ---
# on にすると「調べて」「最新の」等のキーワードで自動検索
# pip3 install duckduckgo-search --break-system-packages
WEB_SEARCH=on

# --- STT (Speech-to-Text) ---
# faster-whisper / Moonshine を選択
STT_ENGINE=faster-whisper
# モデルサイズ: tiny / base / small
# base (int8): ~1.8秒, 日本語精度良好 ← 推奨
# small:       ~9秒,   日本語精度最良
STT_MODEL_SIZE=base
# 言語
STT_LANGUAGE=ja

# --- TTS (Text-to-Speech) ---
# VOICEVOX を優先、未起動時は Edge TTS にフォールバック
TTS_ENGINE=voicevox
VOICEVOX_URL=http://127.0.0.1:50021
# ずんだもん (speaker ID: 3 = ずんだもん ノーマル)
VOICEVOX_SPEAKER_ID=3
# フォールバック
TTS_FALLBACK=edge-tts
EDGE_TTS_VOICE=ja-JP-NanamiNeural

# --- オーディオデバイス (Pi 向け) ---
# USBスピーカーフォンのデバイス名 (arecord -l / aplay -l で確認)
# 空欄ならデフォルトデバイスを使用
AUDIO_INPUT_DEVICE=plughw:2,0
AUDIO_OUTPUT_DEVICE=plughw:2,0
# サンプルレート
AUDIO_SAMPLE_RATE=48000

# --- 動作モード ---
# chat: 会話モード
MODE=chat
# ウェイクワード (空欄で常時リスニング)
WAKE_WORD=ずんだもん
# 無音タイムアウト (秒)
SILENCE_TIMEOUT=2.0
# 最大録音時間 (秒)
MAX_RECORD_SECONDS=30

# --- ログ ---
LOG_LEVEL=INFO
LOG_FILE=/opt/ai-secretary/voice-bridge/logs/voice-bridge.log
