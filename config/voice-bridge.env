# ============================================================
#  voice-bridge 設定 — Raspberry Pi 5 向け
# ============================================================

# --- キャラクター ---
# zundamon: ずんだもん (語尾「〜のだ」)     [VOICEVOX]
# metan:    四国めたん (お嬢様口調)          [VOICEVOX]
# tsumugi:  春日部つむぎ (ギャル口調)       [VOICEVOX]
# lilin:    リリンちゃん (小悪魔メスガキ)   [COEIROINK]
# normal:   通常の丁寧語                     [VOICEVOX]
CHARACTER=zundamon

# --- LLM バックエンド (デュアルLLM対応) ---
#
# ローカル LLM (OpenClaw): 通常の秘書業務・作業指示
# クラウド LLM (GLM等):    ウェブ検索が必要な質問
#
# クラウド側 (CLOUD_LLM_*) が設定されていれば自動でデュアルLLMモード。
# 未設定ならシングルLLMモード (ローカルのみ)。
# クラウドLLM失敗時はローカルにフォールバック。
# 検索結果はOpenClawのメモリに自動保存される。

# --- ローカル LLM (OpenClaw) ---
LLM_BACKEND=openai
OPENAI_API_BASE=http://127.0.0.1:18789/v1
OPENAI_API_KEY=d0e4672fb02025b674ce49665155ff94c819426eaafca2cf
OPENAI_MODEL=openclaw

# --- クラウド LLM (検索時に使用) ---
# 3つとも設定するとデュアルLLMが有効になる
CLOUD_LLM_BASE=https://open.bigmodel.cn/api/paas/v4
CLOUD_LLM_KEY=your-glm-api-key
CLOUD_LLM_MODEL=glm-4-flash
CLOUD_LLM_BACKEND=openai
#
# ◆ 他のクラウドLLM例:
# OpenAI GPT-4o:
#   CLOUD_LLM_BASE=https://api.openai.com/v1
#   CLOUD_LLM_KEY=sk-...
#   CLOUD_LLM_MODEL=gpt-4o
#
# Groq:
#   CLOUD_LLM_BASE=https://api.groq.com/openai/v1
#   CLOUD_LLM_KEY=gsk_...
#   CLOUD_LLM_MODEL=llama-3.3-70b-versatile

# --- OpenClaw メモリ ---
# 検索結果を保存するディレクトリ (memory/YYYY-MM-DD.md)
OPENCLAW_MEMORY_DIR=/opt/ai-secretary/openclaw/memory

# --- Google Gemini API ---
# LLM_BACKEND=gemini または CLOUD_LLM_BACKEND=gemini の場合に使用
# pip3 install google-generativeai --break-system-packages
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- ウェブ検索 (DuckDuckGo) ---
# on にすると「調べて」「最新の」等のキーワードで自動検索
# pip3 install duckduckgo-search --break-system-packages
WEB_SEARCH=on

# --- STT (Speech-to-Text) ---
# faster-whisper / Moonshine を選択
STT_ENGINE=faster-whisper
# モデルサイズ: tiny / base / small
# base (int8): ~1.8秒, 日本語精度良好 ← 推奨
# small:       ~9秒,   日本語精度最良
STT_MODEL_SIZE=base
# 言語
STT_LANGUAGE=ja

# --- TTS (Text-to-Speech) ---
# voicevox:   VOICEVOX (Pi ローカル or リモート)
# coeiroink:  COEIROINK v2 (リモート PC)
TTS_ENGINE=voicevox
VOICEVOX_URL=http://127.0.0.1:50021
# スピーカーID — 未設定なら CHARACTER から自動判定:
#   zundamon=3, metan=2, tsumugi=8, normal=3
# 明示的に指定する場合はコメント解除:
#VOICEVOX_SPEAKER_ID=3
#
# --- COEIROINK (TTS_ENGINE=coeiroink の場合) ---
# Ubuntu PC (evox2) で COEIROINK エンジンを起動しておく
COEIROINK_URL=http://192.168.4.85:50033
COEIROINK_SPEAKER_UUID=cb11bdbd-78fc-4f16-b528-a400bae1782d
COEIROINK_STYLE_ID=92
# スタイル: 90=のーまる, 91=ささやき, 92=メスガキ, 93=理解らされ
#
# フォールバック
TTS_FALLBACK=edge-tts
EDGE_TTS_VOICE=ja-JP-NanamiNeural

# --- オーディオデバイス (Pi 向け) ---
# USBスピーカーフォンのデバイス名 (arecord -l / aplay -l で確認)
# 空欄ならデフォルトデバイスを使用
AUDIO_INPUT_DEVICE=plughw:2,0
AUDIO_OUTPUT_DEVICE=plughw:2,0
# サンプルレート
AUDIO_SAMPLE_RATE=48000

# --- 動作モード ---
# chat: 会話モード
MODE=chat
# ウェイクワード (空欄で常時リスニング)
WAKE_WORD=ずんだもん
# 無音タイムアウト (秒)
SILENCE_TIMEOUT=2.0
# 最大録音時間 (秒)
MAX_RECORD_SECONDS=30

# --- ログ ---
LOG_LEVEL=INFO
LOG_FILE=/opt/ai-secretary/voice-bridge/logs/voice-bridge.log
